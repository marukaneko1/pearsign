# Copy this file to android/keystore.properties (never commit the real file).
# Used by android/app/build.gradle for release signing.
#
# Generate a keystore with:
#   keytool -genkey -v -keystore pearsign.keystore -alias pearsign \
#     -keyalg RSA -keysize 2048 -validity 10000

storeFile=../pearsign.keystore
storePassword=your-keystore-password
keyAlias=pearsign
keyPassword=your-key-password
