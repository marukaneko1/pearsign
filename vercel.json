{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron?tasks=reminders",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron?tasks=retention,billing",
      "schedule": "0 2 * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/cron",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0"
        }
      ]
    }
  ]
}
