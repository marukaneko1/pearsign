# ===== REQUIRED =====
DATABASE_URL=postgresql://user:password@localhost:5432/pearsign

# ===== AUTHENTICATION =====
# Generate with: openssl rand -hex 32
ADMIN_SECRET_KEY=your-secure-random-string
CERT_ENCRYPTION_KEY=your-secure-random-string
JWT_SECRET=your-jwt-secret
SESSION_SECRET=your-session-secret

# ===== EMAIL (SendGrid) =====
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=PearSign

# ===== AI INTEGRATIONS =====
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=

# ===== PAYMENTS (Stripe) =====
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Stripe price IDs for each plan (create these in your Stripe Dashboard)
STRIPE_STARTER_MONTHLY_PRICE_ID=
STRIPE_STARTER_YEARLY_PRICE_ID=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_YEARLY_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=

# ===== SMS (Twilio) =====
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ===== STORAGE =====
# Local uploads directory (used when GCS is not configured)
PRIVATE_OBJECT_DIR=./uploads
# Google Cloud Storage (optional, for production file storage)
GCS_BUCKET_NAME=
GCS_PROJECT_ID=

# ===== INTEGRATIONS (OAuth) =====
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DROPBOX_CLIENT_ID=
DROPBOX_CLIENT_SECRET=
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
# Optional: override Salesforce login URL (default: https://login.salesforce.com)
# SALESFORCE_LOGIN_URL=https://login.salesforce.com

# ===== PAYMENTS (Square) =====
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
SQUARE_WEBHOOK_SIGNATURE_KEY=

# ===== PAYMENTS (Authorize.Net) =====
AUTHORIZENET_API_LOGIN_ID=
AUTHORIZENET_TRANSACTION_KEY=
AUTHORIZENET_SIGNATURE_KEY=

# ===== MOBILE (Capacitor) =====
# Optional: set only for local dev live-reload. Leave unset for production builds.
# CAPACITOR_SERVER_URL=https://your-dev-tunnel.example.com

# ===== APP CONFIG =====
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
