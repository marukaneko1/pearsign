# ===== REQUIRED =====
DATABASE_URL=postgresql://user:password@localhost:5432/pearsign

# ===== AUTHENTICATION =====
ADMIN_SECRET_KEY=your-secure-random-string
CERT_ENCRYPTION_KEY=your-secure-random-string
JWT_SECRET=your-jwt-secret

# ===== EMAIL (SendGrid) =====
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# ===== AI INTEGRATIONS =====
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=

# ===== PAYMENTS (Stripe) =====
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ===== SMS (Twilio) =====
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ===== STORAGE =====
PRIVATE_OBJECT_DIR=./uploads
GCS_BUCKET_NAME=
GCS_PROJECT_ID=

# ===== INTEGRATIONS (OAuth) =====
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DROPBOX_CLIENT_ID=
DROPBOX_CLIENT_SECRET=
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=

# ===== APP CONFIG =====
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
